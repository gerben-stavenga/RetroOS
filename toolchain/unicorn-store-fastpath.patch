Restore QEMU's store fast path (RetroOS).

Upstream unicorn stubbed out QEMU's dirty-memory bitmap
(cpu_physical_memory_is_clean() hardwired to true), which forces
TLB_NOTDIRTY onto every writable page at TLB-fill time and so funnels
EVERY guest store through helper_*_st*_mmu -> notdirty_write: a
flatview lookup plus (for EXEC-mapped RAM) page_collection_lock +
tb_invalidate_phys_page_fast per store. Store-heavy guests (DOS/4GW
init clearing tens of MB: Raptor) run ~1000x slower than stock QEMU.

QEMU only traps stores to pages that hold translated code, invalidates
the TBs on the first write, and lets the inline fast path resume. The
fork already kept both halves of that dance (notdirty_write ->
tlb_set_dirty, tb_gen_code -> tlb_reset_dirty_by_vaddr); restore the
two broken decision points:

1. At TLB fill, consult the TB page table (the ground truth the bitmap
   approximated) instead of the stubbed is_clean.
2. Don't count *_UNMAPPED hooks in uc_mem_hook_installed: they fire
   from the unmapped paths (tlb_fill / mr == NULL), never from a store
   that hit a mapped TLB entry, so they must not pin mapped pages on
   the slow path. (Bounded UC_HOOK_MEM_READ/WRITE/_PROT hooks still
   force the slow path exactly as before.)

Known pre-existing limit (unchanged): tlb_reset_dirty_by_vaddr re-arms
NOTDIRTY by virtual address only, so SMC through a second virtual alias
of a code page can miss invalidation - same as the fork's behavior for
hookless users before this patch.

diff -ur a/qemu/accel/tcg/cputlb.c b/qemu/accel/tcg/cputlb.c
--- a/qemu/accel/tcg/cputlb.c	2026-06-11 19:34:32.038402663 -0700
+++ b/qemu/accel/tcg/cputlb.c	2026-06-11 19:34:54.694742053 -0700
@@ -874,7 +874,7 @@
         if (prot & PAGE_WRITE) {
             if (section->readonly) {
                 write_address |= TLB_DISCARD_WRITE;
-            } else if (cpu_physical_memory_is_clean(iotlb)) {
+            } else if (uc_phys_page_has_tb(cpu->uc, iotlb)) {
                 write_address |= TLB_NOTDIRTY;
             }
         }
diff -ur a/qemu/accel/tcg/translate-all.c b/qemu/accel/tcg/translate-all.c
--- a/qemu/accel/tcg/translate-all.c	2026-06-11 19:34:32.029260193 -0700
+++ b/qemu/accel/tcg/translate-all.c	2026-06-11 19:34:54.693994214 -0700
@@ -421,6 +421,17 @@
     return page_find_alloc(uc, index, 0);
 }
 
+/* RetroOS: the dirty-memory bitmap is stubbed out in this fork, so the
+ * TLB-fill code asks the TB page table directly: only pages that hold
+ * translated code need their stores trapped (for SMC invalidation).
+ * Replaces cpu_physical_memory_is_clean(), which the stub made return
+ * true for everything and thereby disabled the store fast path. */
+bool uc_phys_page_has_tb(struct uc_struct *uc, tb_page_addr_t addr)
+{
+    PageDesc *pd = page_find(uc, addr >> TARGET_PAGE_BITS);
+    return pd != NULL && pd->first_tb != 0;
+}
+
 static void page_lock_pair(struct uc_struct *uc, PageDesc **ret_p1, tb_page_addr_t phys1,
                            PageDesc **ret_p2, tb_page_addr_t phys2, int alloc);
 
diff -ur a/qemu/include/exec/exec-all.h b/qemu/include/exec/exec-all.h
--- a/qemu/include/exec/exec-all.h	2026-06-11 19:34:32.047484601 -0700
+++ b/qemu/include/exec/exec-all.h	2026-06-11 19:34:54.695132178 -0700
@@ -477,12 +477,15 @@
 hwaddr memory_region_section_get_iotlb(CPUState *cpu,
                                        MemoryRegionSection *section);
 
+/* translate-all.c; RetroOS, see uc_mem_hook_installed below. */
+bool uc_phys_page_has_tb(struct uc_struct *uc, tb_page_addr_t addr);
+
+/* RetroOS: *_UNMAPPED hooks deliberately not counted - they fire from
+ * the unmapped paths (tlb_fill / mr == NULL in the store helpers),
+ * never for an access that hit a mapped TLB entry, so a global
+ * unmapped hook must not pin every mapped page on the slow path. */
 static inline bool uc_mem_hook_installed(struct uc_struct *uc, hwaddr paddr)
 {
-    if (HOOK_EXISTS_BOUNDED(uc, UC_HOOK_MEM_FETCH_UNMAPPED, paddr))
-        return true;
-    if (HOOK_EXISTS_BOUNDED(uc, UC_HOOK_MEM_READ_UNMAPPED, paddr))
-        return true;
     if (HOOK_EXISTS_BOUNDED(uc, UC_HOOK_MEM_READ, paddr))
         return true;
     if (HOOK_EXISTS_BOUNDED(uc, UC_HOOK_MEM_READ_PROT, paddr))
@@ -493,8 +496,6 @@
         return true;
     if (HOOK_EXISTS_BOUNDED(uc, UC_HOOK_MEM_WRITE, paddr))
         return true;
-    if (HOOK_EXISTS_BOUNDED(uc, UC_HOOK_MEM_WRITE_UNMAPPED, paddr))
-        return true;
     if (HOOK_EXISTS_BOUNDED(uc, UC_HOOK_MEM_WRITE_PROT, paddr))
         return true;
     return false;
