load("@rules_rust//rust:defs.bzl", "rust_binary")
load("//toolchain:musl_transition.bzl", "musl64_binary")

rust_binary(
    name = "hello64_linux_bin",
    srcs = ["src/main.rs"],
    edition = "2024",
    rustc_flags = ["-Copt-level=s", "-Cstrip=symbols", "-Clinker-flavor=ld.lld", "-Clinker=rust-lld", "-Crelocation-model=static"],
)

musl64_binary(
    name = "hello64_linux",
    binary = ":hello64_linux_bin",
    visibility = ["//visibility:public"],
)
