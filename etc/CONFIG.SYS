# RetroOS boot config -- read by the kernel before the first DOS program
# runs. Each non-comment line is KEY=VALUE; lines override or extend the
# kernel's built-in master env (PATH only). Edit freely -- this file
# lives on the ext4 root (read/write).

COMSPEC=C:\BOOT\COMMAND.COM
PATH=C:\;C:\BOOT;C:\TC;C:\BORLANDC\BIN
ADLIB=A388
BLASTER=A220 I7 D1 H5 P330 T6
ULTRASND=240,1,1,5,5
ULTRADIR=C:\ULTRASND
